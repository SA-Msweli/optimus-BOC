# Optimus Backend Environment
# Copy to /etc/optimus/backend.env on EC2 and fill in values.
# This file is read by the optimus.service systemd unit.

# Server
PORT=8000

# PostgreSQL
DATABASE_URL=postgres://optimus:MASTER_Optimust#BOC@localhost:5432/optimus?sslmode=disable

# Ethereum (Sepolia)
CHAIN_RPC_URL=https://sepolia.infura.io/v3/<YOUR_INFURA_KEY>
PRIVATE_KEY=<DEPLOYER_PRIVATE_KEY>

# Contract addresses (Sepolia)
DID_REGISTRY_ADDRESS=0x0E9D33b0cA7c7e93F4F5e413C35cE0E518040296
BNPL_MANAGER_ADDRESS=0x4d99F01530F9b5Ee58C13E52a114d79cF397c1f4
LOAN_MANAGER_ADDRESS=0xbB0D4067488edf4a007822407e2486412dC8D39D
DAO_MANAGER_ADDRESS=0x5612dB018f17E82D76E79a77aA75Bbf42E40C9B1
TOKEN_VAULT_ADDRESS=0x4C70E0Ae715d04e3a6e65a70191276a5D0E5B66a

# Privy authentication
PRIVY_APP_ID=<YOUR_PRIVY_APP_ID>
PRIVY_APP_SECRET=<YOUR_PRIVY_APP_SECRET>
# PRIVY_JWKS is auto-derived from PRIVY_APP_ID if omitted
