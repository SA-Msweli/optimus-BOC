# Optimus protocol backend sample configuration

# HTTP server port
PORT=8080

# PostgreSQL connection string used by the backend
DATABASE_URL=postgres://user:pass@localhost:5432/optimus?sslmode=disable

# Privy configuration (required for JWT auth on protected routes)
PRIVY_APP_ID=cmiyiw1s40005jx0dho2x9bn4
PRIVY_APP_SECRET=
PRIVY_JWKS=https://auth.privy.io/api/v1/apps/cmiyiw1s40005jx0dho2x9bn4/jwks.json

# Ethereum JSON-RPC endpoint
CHAIN_RPC_URL=https://sepolia.infura.io/v3/<KEY>

# Deployed contract addresses (Sepolia addresses shown earlier as example)
BNPL_MANAGER_ADDRESS=
DAO_MANAGER_ADDRESS=
LOAN_MANAGER_ADDRESS=
TOKEN_VAULT_ADDRESS=
DID_REGISTRY_ADDRESS=

# Private key for signing transactions (0x-prefixed)
PRIVATE_KEY=
